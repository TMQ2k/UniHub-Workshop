# ============================================================
# UniHub Workshop — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- Application ---
APP_PORT=3000
NODE_ENV=development

# --- PostgreSQL (phải khớp với infra/.env) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=unihub_workshop
POSTGRES_USER=unihub
POSTGRES_PASSWORD=unihub_secret

# --- Redis (phải khớp với infra/.env) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=unihub_redis_secret

# --- JWT ---
JWT_ACCESS_SECRET=unihub_jwt_access_s3cret_2026
JWT_REFRESH_SECRET=unihub_jwt_refresh_s3cret_2026
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- Google AI / Gemini (dùng cho AI Summary) ---
GOOGLE_AI_API_KEY=

# --- Payment Gateway (Mock) ---
PAYMENT_GATEWAY_URL=http://localhost:3001

# --- QR Code HMAC ---
QR_HMAC_SECRET=unihub_qr_hmac_s3cret_2026

# --- SMTP (Ethereal - test email) ---
# Tạo tài khoản tại: https://ethereal.email/create
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_user@ethereal.email
SMTP_PASS=your_ethereal_password
SMTP_FROM=noreply@unihub.edu.vn