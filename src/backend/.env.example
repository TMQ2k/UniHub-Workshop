# ============================================================
# UniHub Workshop — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- Application ---
APP_PORT=3000
NODE_ENV=development

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=unihub_workshop
POSTGRES_USER=unihub
POSTGRES_PASSWORD=unihub_secret

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=unihub_redis_secret

# --- JWT ---
JWT_ACCESS_SECRET=your_access_secret_change_me
JWT_REFRESH_SECRET=your_refresh_secret_change_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=

# --- Payment Gateway (Mock) ---
PAYMENT_GATEWAY_URL=http://localhost:3001
